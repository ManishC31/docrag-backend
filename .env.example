# Application
APP_NAME="RAG Application"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/ragdb
SYNC_DATABASE_URL=postgresql+psycopg2://raguser:ragpassword@localhost:5432/ragdb

# Qdrant
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=["pdf","txt","docx"]

# RAG Settings
MAX_DOCUMENTS_PER_GROUP=3
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
CHAT_MODEL=gpt-4o
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_CHUNKS=5

# Admin
ADMIN_EMAIL=manishchavan80@gmail.com
