# Application
APP_NAME="RAG Application"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# Database (Neon or any PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require
SYNC_DATABASE_URL=postgresql+psycopg2://user:password@host/dbname?sslmode=require

# Qdrant
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# Security
SECRET_KEY=your-minimum-32-char-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# CORS — add your Railway backend URL and frontend URL
BACKEND_CORS_ORIGINS=["https://your-frontend.up.railway.app","http://localhost:5173"]

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=["pdf","txt","docx"]

# RAG Settings
MAX_DOCUMENTS_PER_GROUP=3
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
CHAT_MODEL=gpt-4o
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_CHUNKS=5

# Admin
ADMIN_EMAIL=your-email@example.com
